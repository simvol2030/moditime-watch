# ============================================
# MODITIMEWATCH BACKEND (AdminJS) - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# SERVER
# ============================================

# Server port (default: 3000)
PORT=3000

# Node Environment (development | production)
NODE_ENV=development

# ============================================
# SECURITY (REQUIRED IN PRODUCTION!)
# ============================================

# Cookie encryption secret (minimum 32 characters)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=change-this-to-a-random-string-at-least-32-chars

# Session encryption secret (minimum 32 characters)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-another-random-string-32-chars

# ============================================
# INITIAL ADMIN ACCOUNT
# ============================================
# Used only for first-time setup when no admins exist
# After creating admin via UI, you can remove these

# Admin email (will be username for login)
ADMIN_EMAIL=admin@example.com

# Admin password (will be hashed with bcrypt)
# IMPORTANT: Change this immediately after first login!
ADMIN_PASSWORD=ChangeThisPassword123!

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production, ensure:
#
# 1. NODE_ENV=production
# 2. COOKIE_SECRET is a unique random string (32+ chars)
# 3. SESSION_SECRET is a unique random string (32+ chars)
# 4. ADMIN_EMAIL is your real admin email
# 5. ADMIN_PASSWORD is a strong password (change after first login)
# 6. .env file has restricted permissions (chmod 600)
# 7. .env is in .gitignore (never commit secrets!)
