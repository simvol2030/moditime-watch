# ============================================
# MODITIMEWATCH FRONTEND - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# SECURITY (REQUIRED)
# ============================================

# Session Secret for encrypting session cookies
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=your-random-32-byte-base64-encoded-secret-here

# ============================================
# ENVIRONMENT
# ============================================

# Node Environment (development | production)
NODE_ENV=development

# ============================================
# EMAIL NOTIFICATIONS (SMTP)
# ============================================
# Configure to enable real email sending for order confirmations

# SMTP Server (e.g., smtp.gmail.com, smtp.yandex.ru, smtp.mail.ru)
SMTP_HOST=

# SMTP Port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP Authentication
SMTP_USER=
SMTP_PASSWORD=

# Sender email address (usually same as SMTP_USER)
SMTP_FROM=

# Use SSL instead of TLS (set to "true" for port 465)
# SMTP_SECURE=false

# ============================================
# TELEGRAM NOTIFICATIONS
# ============================================
# Configure to receive instant order notifications in Telegram

# Bot token from @BotFather (format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz)
TELEGRAM_BOT_TOKEN=

# Chat/Channel ID to send notifications
# Get it: send message to bot, then call https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_CHAT_ID=

# ============================================
# ADMIN NOTIFICATIONS
# ============================================

# Email address to receive admin order notifications
ADMIN_EMAIL=

# ============================================
# ANALYTICS (OPTIONAL)
# ============================================
# PUBLIC_ prefix makes these available in browser

# Google Tag Manager ID (GTM-XXXXXX)
PUBLIC_GTM_ID=

# Google Analytics 4 ID (G-XXXXXXXXXX)
PUBLIC_GA_ID=

# Yandex Metrika ID (numeric)
PUBLIC_YM_ID=

# ============================================
# EXAMPLE CONFIGURATIONS
# ============================================

# --- Gmail SMTP ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password  # Use App Password, not regular password!
# SMTP_FROM=your-email@gmail.com

# --- Yandex SMTP ---
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@yandex.ru
# SMTP_PASSWORD=your-password
# SMTP_FROM=your-email@yandex.ru

# --- Mail.ru SMTP ---
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@mail.ru
# SMTP_PASSWORD=your-password
# SMTP_FROM=your-email@mail.ru
